# Symfony Docker Starter - Configuration par défaut

# Projet symfony par défaut (utilisé si PROJECT_NAME_PRIO n'est pas défini)
PROJECT_NAME=symfony
SYMFONY_VERSION=lts

# Stack
WEBSERVER=apache
DATABASE=mariadb

# Ports
HTTP_PORT=8080
HTTPS_PORT=8443

# Base de données
DB_ROOT_PASSWORD=root
DB_NAME=symfony
DB_USER=symfony
DB_PASSWORD=symfony
MYSQL_PORT=3306
POSTGRES_PORT=5432

# Admins DB
PHPMYADMIN_PORT=8081
PGADMIN_PORT=5050
PGADMIN_PASSWORD=password_admin

# MailDev
MAILDEV_WEB_PORT=1080
MAILDEV_SMTP_PORT=1025

#PHPSTAN
PHPSTAN_VERSION=^1.12

#Rector (pour forcer une version, mais attention comptatibilité symfony)
#RECTOR_VERSION=^1.2

# UID/GID de ton utilisateur Linux (hôte) → permissions parfaites après docker up
WWW_UID=1000
WWW_GID=1000

#Nom du projet "docker"
COMPOSE_PROJECT_NAME=symfony_docker_starter_kit