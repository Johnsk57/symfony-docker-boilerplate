# =====================================================
# 🌐 NGINX CONF - SYMFONY + MAILDEV (envsubst)
# =====================================================
#
# ARCHITECTURE :
# ✅ Upstream php-fpm:9000 (Docker)
# ✅ Gzip optimisé (CSS/JS/images)
# ✅ Symfony front controller (try_files)
# ✅ Cache 1 an assets statiques
# ✅ Multi-domain : localhost + maildev.localhost
# ✅ HTTP → HTTPS 301 global
# =====================================================

upstream php-fpm {
    server php-fpm:9000;  # 🎯 Docker compose service
}

# =====================================================
# 💨 GZIP GLOBAL (perf Lighthouse)
# =====================================================
gzip on;
gzip_vary on;
gzip_min_length 1024;
gzip_proxied any;
gzip_comp_level 6;  # ⚖️  Équilibre vitesse/compression
gzip_types
  text/plain
  text/css
  text/xml
  text/javascript
  application/json
  application/javascript
  application/xml+rss
  image/svg+xml;
# 📉 -70% taille HTML/CSS/JS

# =====================================================
# 🔒 HTTPS SYMFONY (localhost)
# =====================================================
server {
    listen 443 ssl http2;  # 🎯 HTTP/2 multiplex
    ssl_certificate /etc/nginx/certs/selfsigned.crt;
    ssl_certificate_key /etc/nginx/certs/selfsigned.key;
    server_name localhost;
    root /var/www/html/${PROJECT_NAME}/public;  # envsubst
    index index.php;

    # ⚡ CACHE 1 AN ASSETS STATIQUES
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";  # 🎯 Service Worker
        access_log off;  # Perf logs
        try_files $uri =404;
    }

    # 🎯 PHP FPM SYMFONY (security)
    location ~ ^/index\.php(/|$) {
        fastcgi_pass php-fpm;
        fastcgi_split_path_info ^(.+\.php)(/.*)$;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param HTTPS on;
        fastcgi_param SERVER_PORT 443;
        internal;  # 🚫 Accès direct interdit
    }

    # 🎯 FRONT CONTROLLER SYMFONY
    location / {
        try_files $uri /index.php$is_args$args;
    }

    # 🚫 AUTRES .php → 404 (security)
    location ~ \.php$ {
        return 404;
    }
}

# =====================================================
# 📧 MAILDEV PROXY (https://maildev.localhost)
# =====================================================
server {
    listen 443 ssl http2;
    ssl_certificate /etc/nginx/certs/selfsigned.crt;
    ssl_certificate_key /etc/nginx/certs/selfsigned.key;
    server_name maildev.localhost;

    location / {
        proxy_pass http://mail:1080/;  # Docker service
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        # 💡 Headers complets (MailDev UI)
    }
}

# =====================================================
# 🔄 GLOBAL HTTP → HTTPS REDIRECT (301)
# =====================================================
server {
    listen 80;
    server_name localhost maildev.localhost;
    return 301 https://$host$request_uri;
    # 🎯 SEO + sécurité tous domaines
}
